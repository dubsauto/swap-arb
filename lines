from sqlalchemy import create_engine, text

DB_URL = "postgresql://swap_arb:9YDy3ngLW24EtF51WtfVCK2x2ZGaXCBd@dpg-d7f4l41kh4rs73ddv2t0-a.oregon-postgres.render.com/swap_arb_db"

engine = create_engine(DB_URL)

with engine.begin() as conn:
    print("Connected to database.")

    # =========================
    # 1. Add column if not exists
    # =========================
    print("Checking/adding can_use_calculator column...")

    conn.execute(text("""
        ALTER TABLE user_permissions
        ADD COLUMN IF NOT EXISTS can_use_calculator BOOLEAN DEFAULT TRUE;
    """))

    # =========================
    # 2. Create cycle_slots table
    # =========================
    print("Creating cycle_slots table (if not exists)...")

    conn.execute(text("""
    CREATE TABLE IF NOT EXISTS cycle_slots (
        id SERIAL PRIMARY KEY,
        user_id INTEGER NOT NULL REFERENCES users(id) ON DELETE CASCADE,
        name VARCHAR(128) NOT NULL,

        big_balance FLOAT NOT NULL DEFAULT 3000.0,
        small_balance FLOAT NOT NULL DEFAULT 1000.0,
        starting_pips INTEGER NOT NULL DEFAULT 100,
        num_phases INTEGER NOT NULL DEFAULT 3,
        trades_per_phase INTEGER NOT NULL DEFAULT 4,

        losses JSON NOT NULL DEFAULT '[]',

        ea_name VARCHAR(128) DEFAULT 'Cycle_EA_Premium',
        use_name_as_comment BOOLEAN DEFAULT TRUE,
        signal_tf VARCHAR(16) DEFAULT '5',
        ema_period INTEGER DEFAULT 200,
        bb_period INTEGER DEFAULT 20,
        bb_deviation FLOAT DEFAULT 2.0,
        require_closed_candle BOOLEAN DEFAULT TRUE,
        require_close_inside_bb BOOLEAN DEFAULT TRUE,

        cycle_state JSON,

        created_at TIMESTAMP DEFAULT NOW(),
        updated_at TIMESTAMP DEFAULT NOW()
    );
    """))

    # =========================
    # 3. Create cycle_phases table
    # =========================
    print("Creating cycle_phases table (if not exists)...")

    conn.execute(text("""
    CREATE TABLE IF NOT EXISTS cycle_phases (
        id SERIAL PRIMARY KEY,
        slot_id INTEGER NOT NULL REFERENCES cycle_slots(id) ON DELETE CASCADE,
        phase_num INTEGER NOT NULL,

        recovery FLOAT NOT NULL,
        tp_value FLOAT NOT NULL,
        lot FLOAT NOT NULL,
        sl_base_pips INTEGER NOT NULL,
        loss_real FLOAT NOT NULL,
        disallineamento FLOAT NOT NULL,

        trades JSON NOT NULL DEFAULT '[]'
    );
    """))

    # =========================
    # 4. Fix permissions
    # =========================
    print("Updating permissions...")

    # Set all to FALSE
    conn.execute(text("""
        UPDATE user_permissions
        SET can_use_calculator = FALSE;
    """))

    # Enable only admins
    conn.execute(text("""
        UPDATE user_permissions up
        SET can_use_calculator = TRUE
        FROM users u
        WHERE up.user_id = u.id
        AND u.role = 'admin';
    """))

    print("Migration completed successfully.")



